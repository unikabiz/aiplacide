# AIPLACIDE.COM Newsletter Integration Configuration
# Copy this file to .dev.vars for local development
# For production, set these as Cloudflare Pages secrets

# ===== NEWSLETTER PROVIDER SELECTION =====
# Options: 'sendfox' (default), 'convertkit', or 'beehiiv'
NEWSLETTER_PROVIDER=sendfox

# ===== SENDFOX CONFIGURATION (RECOMMENDED) =====
# Get your Personal Access Token from: https://sendfox.com/account/oauth
# Click "Create New Token" and copy the token
# Get your List ID from the URL when viewing a list: https://sendfox.com/lists/XXXXXX
SENDFOX_API_TOKEN=your_sendfox_personal_access_token_here
SENDFOX_LIST_ID=your_list_id_here

# ===== CONVERTKIT CONFIGURATION =====
# Get your API key from: https://app.convertkit.com/account_settings/developer_settings
# Get your Form ID from the form URL or API
CONVERTKIT_API_KEY=your_convertkit_api_key_here
CONVERTKIT_FORM_ID=your_form_id_here

# ===== BEEHIIV CONFIGURATION =====
# Get your API key from: https://app.beehiiv.com/settings/integrations
# Get your Publication ID from Settings > Publication
BEEHIIV_API_KEY=your_beehiiv_api_key_here
BEEHIIV_PUBLICATION_ID=your_publication_id_here

# ===== EMAIL NOTIFICATIONS (RESEND) =====
# Sign up at: https://resend.com
# Add your domain and verify DNS records
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# Email address to receive notifications (contact form, speaking inquiries, etc.)
NOTIFICATION_EMAIL=pierre@aiplacide.com
